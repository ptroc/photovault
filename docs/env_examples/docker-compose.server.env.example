# Docker Compose server deployment environment file example
# Canonical runtime location: deploy/docker/.env

PHOTOVAULT_API_DATABASE_URL=postgresql://photovault_api:change-me@host.docker.internal:5432/photovault
PHOTOVAULT_API_BOOTSTRAP_TOKEN=change-me-bootstrap-token

# Host path bind-mounted into the containers.
PHOTOVAULT_STORAGE_HOST_ROOT=/storage/photovault

# Container-side mount target.
PHOTOVAULT_STORAGE_CONTAINER_ROOT=/var/storage

# Required API storage path inside the container.
PHOTOVAULT_API_STORAGE_ROOT=/var/storage

# Optional API preview settings.
PHOTOVAULT_API_PREVIEW_CACHE_ROOT=/var/.photovault_preview_cache
PHOTOVAULT_API_PREVIEW_MAX_LONG_EDGE=2048
PHOTOVAULT_API_PREVIEW_PASSTHROUGH_SUFFIXES=.jpg,.jpeg
PHOTOVAULT_API_PREVIEW_PLACEHOLDER_SUFFIXES=.avi,.mp4

# Optional server UI preview-path display setting.
PHOTOVAULT_SERVER_UI_PREVIEW_CACHE_ROOT=/var/.photovault_preview_cache

# Optional Nginx host port override.
PHOTOVAULT_NGINX_HTTP_PORT=80
