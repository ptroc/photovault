# photovault-clientd systemd environment file example
# Canonical runtime location: /etc/photovault/photovault-clientd.env

# Optional. Central server API base URL.
PHOTOVAULT_SERVER_BASE_URL=http://127.0.0.1:9301

# Optional. Stable client identifier.
PHOTOVAULT_CLIENT_ID=photovault-client-01

# Optional. Human-friendly operator label.
PHOTOVAULT_CLIENT_DISPLAY_NAME=Studio Ingest Client 01

# Optional. Required only when using bootstrap enrollment.
PHOTOVAULT_CLIENT_BOOTSTRAP_TOKEN=change-me-client-bootstrap-token

# Optional. Positive integer heartbeat interval in seconds.
PHOTOVAULT_CLIENT_HEARTBEAT_INTERVAL_SECONDS=30
