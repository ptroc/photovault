# photovault-server-ui systemd environment file example
# Canonical runtime location: /etc/photovault/photovault-server-ui.env

# Optional. Default is http://127.0.0.1:9301
PHOTOVAULT_SERVER_UI_API_BASE_URL=http://127.0.0.1:9301

# Optional. Keep aligned with the API preview cache root for operator clarity.
PHOTOVAULT_SERVER_UI_PREVIEW_CACHE_ROOT=/var/.photovault_preview_cache
