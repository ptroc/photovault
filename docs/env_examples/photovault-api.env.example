# photovault-api systemd environment file example
# Canonical runtime location: /etc/photovault/photovault-api.env

# Optional for local/demo use, but required for persistent server deployments.
PHOTOVAULT_API_DATABASE_URL=postgresql://photovault_api:change-me@127.0.0.1:5432/photovault

# Required. Absolute path where uploaded and indexed files live.
PHOTOVAULT_API_STORAGE_ROOT=/storage/photovault

# Optional. Enables client bootstrap enrollment when non-empty.
PHOTOVAULT_API_BOOTSTRAP_TOKEN=change-me-bootstrap-token

# Optional. Preview cache directory.
PHOTOVAULT_API_PREVIEW_CACHE_ROOT=/var/.photovault_preview_cache

# Optional. Positive integer. Default is 1024.
PHOTOVAULT_API_PREVIEW_MAX_LONG_EDGE=2048

# Optional. Comma-separated suffixes that should serve the original file.
PHOTOVAULT_API_PREVIEW_PASSTHROUGH_SUFFIXES=.jpg,.jpeg

# Optional. Comma-separated suffixes that should remain placeholder-only.
PHOTOVAULT_API_PREVIEW_PLACEHOLDER_SUFFIXES=.avi,.mp4
